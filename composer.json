{
    "name": "freyr/ci-pipeline-demo",
    "description": "Minimal demo repository for trunk-based CI/CD pipeline with CalVer releases",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpunit/phpunit": "^11.0",
        "qossmic/deptrac": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Demo\\Pipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Demo\\Pipeline\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "deptrac": "deptrac analyse",
        "quality": [
            "@cs-check",
            "@phpstan",
            "@deptrac",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
